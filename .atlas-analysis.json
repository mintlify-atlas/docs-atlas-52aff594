  "keyFeatures": [
    "TypeScript decorators for defining MCP tools, prompts, and resources",
    "Class-based schema validation with compile-time type safety",
    "Built-in authentication with multiple OAuth providers (Auth0, Clerk, Cognito)",
    "Multi-tenant isolation and request-scoped environment injection",
    "Interactive CLI for project scaffolding and service generation",
    "HTTP server with CORS support and session management",
    "Human-in-the-loop elicitation for structured user input",
    "MCP-native UI components with React integration",
    "Automatic service discovery and hot-reload in dev mode",
    "Production-ready observability and monitoring"
  ],
  "publicApiSurface": [
    "@Tool - Decorator for defining callable MCP tools",
    "@Prompt - Decorator for reusable prompt templates",
    "@Resource - Decorator for data endpoints",
    "@SchemaConstraint - Property decorator for validation rules",
    "@Optional - Mark schema properties as optional",
    "@Authenticated - Class/method decorator for auth requirements",
    "MCPServer - Main server class for service registration",
    "createHTTPServer() - Create HTTP server with MCP support",
    "classToJsonSchemaWithConstraints() - Generate JSON Schema from TypeScript classes",
    "AuthProvider - Authentication provider interface",
    "elicit() - Function for structured user input collection",
    "@UIApp - Decorator for MCP UI components",
    "@UserEnvs - Decorator for request-scoped env injection",
    "leanmcp create - CLI command to create new projects",
    "leanmcp add - CLI command to add services",
    "DynamoDBSessionStore - Session storage for multi-tenant apps",
    "InMemorySessionStore - In-memory session storage"
  ]
}
